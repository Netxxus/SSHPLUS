#!/bin/bash
clear
echo -e "\033[1;31mв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\033[0m"
echo -e "\033[1;37m  ESTADO DEL SISTEMA - @Netxxus\033[0m"
echo -e "\033[1;31mв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\033[0m"
echo ""
# OS
os=$(cat /etc/os-release 2>/dev/null | grep PRETTY_NAME | cut -d'"' -f2)
echo -e "\033[1;33m  OS:\033[1;37m $os"
# Kernel
kernel=$(uname -r)
echo -e "\033[1;33m  Kernel:\033[1;37m $kernel"
# Uptime
uptime_sec=$(cat /proc/uptime | awk '{print $1}' | cut -d. -f1)
days=$((uptime_sec / 86400))
hours=$(( (uptime_sec % 86400) / 3600 ))
mins=$(( (uptime_sec % 3600) / 60 ))
echo -e "\033[1;33m  Uptime:\033[1;37m ${days}d ${hours}h ${mins}m"
echo ""
# CPU
cpu_idle=$(top -bn1 | grep "Cpu(s)" | awk '{print $8}' | cut -d. -f1)
cpu_used=$((100 - ${cpu_idle:-0}))
if [[ $cpu_used -ge 80 ]]; then
    echo -e "\033[1;33m  CPU:\033[1;31m ${cpu_used}%\033[0m"
elif [[ $cpu_used -ge 50 ]]; then
    echo -e "\033[1;33m  CPU:\033[1;33m ${cpu_used}%\033[0m"
else
    echo -e "\033[1;33m  CPU:\033[1;32m ${cpu_used}%\033[0m"
fi
# RAM
ram_total=$(free -m | awk '/Mem/{print $2}')
ram_used=$(free -m | awk '/Mem/{print $3}')
ram_pct=$((ram_used * 100 / ram_total))
if [[ $ram_pct -ge 80 ]]; then
    echo -e "\033[1;33m  RAM:\033[1;31m ${ram_used}MB / ${ram_total}MB (${ram_pct}%)\033[0m"
elif [[ $ram_pct -ge 50 ]]; then
    echo -e "\033[1;33m  RAM:\033[1;33m ${ram_used}MB / ${ram_total}MB (${ram_pct}%)\033[0m"
else
    echo -e "\033[1;33m  RAM:\033[1;32m ${ram_used}MB / ${ram_total}MB (${ram_pct}%)\033[0m"
fi
# Disk
disk_used=$(df -h / | awk 'NR==2{print $5}' | tr -d '%')
disk_info=$(df -h / | awk 'NR==2{print $3 " / " $2}')
if [[ $disk_used -ge 80 ]]; then
    echo -e "\033[1;33m  DISCO:\033[1;31m $disk_info (${disk_used}%)\033[0m"
elif [[ $disk_used -ge 50 ]]; then
    echo -e "\033[1;33m  DISCO:\033[1;33m $disk_info (${disk_used}%)\033[0m"
else
    echo -e "\033[1;33m  DISCO:\033[1;32m $disk_info (${disk_used}%)\033[0m"
fi
# Swap
swap_total=$(free -m | awk '/Swap/{print $2}')
swap_used=$(free -m | awk '/Swap/{print $3}')
echo -e "\033[1;33m  SWAP:\033[1;37m ${swap_used}MB / ${swap_total}MB"
echo ""
echo -e "\033[1;31mв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\033[0m"
echo -e "\033[1;33m  SERVICIOS:\033[0m"
for svc in ssh openvpn dropbear apache2 squid; do
    status=$(service "$svc" status 2>/dev/null | grep -o "running\|active" | head -1)
    [[ "$status" == "running" || "$status" == "active" ]] && echo -e "    \033[1;32m$svc: ACTIVO\033[0m" || echo -e "    \033[1;31m$svc: INACTIVO\033[0m"
done
echo ""
_users=$(awk -F: '$3>=1000 {print $1}' /etc/passwd | grep -v nobody | wc -l)
_on=$(ps -x | grep sshd | grep -v root | grep priv | wc -l)
echo -e "\033[1;33m  Usuarios:\033[1;37m $_users"
echo -e "\033[1;33m  Online:\033[1;32m $_on\033[0m"
echo ""
echo -ne "\033[1;37m  [ENTER] Volver"; read
