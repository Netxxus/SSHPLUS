#!/bin/bash
clear
echo -e "\033[1;31mв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\033[0m"
echo -e "\033[1;37m  CAMBIAR PUERTO SSH - @Netxxus\033[0m"
echo -e "\033[1;31mв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\033[0m"
echo ""
puerto_actual=$(grep -E "^Port " /etc/ssh/sshd_config | awk '{print $2}')
[[ -z "$puerto_actual" ]] && puerto_actual="22"
echo -e "\033[1;37m  Puerto actual: \033[1;31m$puerto_actual\033[0m"
echo ""
echo -ne "\033[1;32m  Nuevo puerto (1-65535):\033[1;37m "; read nuevo_puerto
[[ -z "$nuevo_puerto" ]] && { echo -e "\033[1;31m  Puerto vacio!\033[0m"; sleep 2; exit 1; }
[[ ! "$nuevo_puerto" =~ ^[0-9]+$ ]] && { echo -e "\033[1;31m  Puerto invalido!\033[0m"; sleep 2; exit 1; }
[[ $nuevo_puerto -lt 1 || $nuevo_puerto -gt 65535 ]] && { echo -e "\033[1;31m  Puerto fuera de rango!\033[0m"; sleep 2; exit 1; }
[[ "$nuevo_puerto" == "$puerto_actual" ]] && { echo -e "\033[1;33m  Es el mismo puerto!\033[0m"; sleep 2; exit 1; }
echo ""
echo -e "\033[1;33m  Cambiando puerto de $puerto_actual a $nuevo_puerto...\033[0m"
sed -i "s/^Port $puerto_actual/Port $nuevo_puerto/" /etc/ssh/sshd_config
if grep -q "^Port $nuevo_puerto" /etc/ssh/sshd_config; then
    service ssh restart >/dev/null 2>&1
    echo -e "\033[1;32m  Puerto cambiado a $nuevo_puerto correctamente!\033[0m"
    echo -e "\033[1;31m  IMPORTANTE: Conectate con el nuevo puerto: ssh -p $nuevo_puerto usuario@IP\033[0m"
else
    echo -e "\033[1;31m  Error al cambiar el puerto!\033[0m"
fi
echo ""
echo -ne "\033[1;37m  [ENTER] Volver"; read
