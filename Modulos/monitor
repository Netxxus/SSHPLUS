#!/bin/bash

RED='\033[1;31m'
GREEN='\033[1;32m'
YELLOW='\033[1;33m'
CYAN='\033[1;36m'
WHITE='\033[1;37m'
RESET='\033[0m'

USERS_DB="$HOME/usuarios.db"

get_uptime() {
    uptime -p 2>/dev/null || uptime | sed 's/.*up/up/' | sed 's/,.*load.*//'
}

get_ram() {
    free -h 2>/dev/null | awk '/Mem:/{printf "%s/%s", $3, $2}' || echo "N/A"
}

get_cpu() {
    top -bn1 2>/dev/null | grep "Cpu(s)" | awk '{print $2}' || echo "N/A"
}

count_connections() {
    local user="$1"
    who 2>/dev/null | awk '{print $1}' | grep -c "^${user}$" 2>/dev/null || echo 0
}

is_active() {
    local user="$1"
    if who 2>/dev/null | awk '{print $1}' | grep -q "^${user}$"; then
        echo -e "${GREEN}● ACTIVE${RESET}"
    else
        echo -e "${YELLOW}○ IDLE${RESET}"
    fi
}

print_header() {
    clear
    echo -e "${RED}╔══════════════════════════════════════════════════════════╗${RESET}"
    echo -e "${RED}║${WHITE}              SSHPLUS SERVER MONITOR                      ${RED}║${RESET}"
    echo -e "${RED}╠══════════════════════════════════════════════════════════╣${RESET}"
    echo -e "${RED}║${CYAN} Uptime: ${WHITE}$(get_uptime)${RED}║${RESET}"
    echo -e "${RED}║${CYAN} RAM:    ${WHITE}$(get_ram)${RED}  ║${RESET}"
    echo -e "${RED}║${CYAN} CPU:    ${WHITE}$(get_cpu)%${RED}     ║${RESET}"
    echo -e "${RED}╠══════════════════════════════════════════════════════════╣${RESET}"
    echo -e "${RED}║${WHITE} USERNAME          STATUS        CONNECTIONS             ${RED}║${RESET}"
    echo -e "${RED}╠══════════════════════════════════════════════════════════╣${RESET}"
}

print_footer() {
    echo -e "${RED}╚══════════════════════════════════════════════════════════╝${RESET}"
    echo ""
    echo -e "${YELLOW}Auto-refresh in 5s | Press ENTER to return to menu${RESET}"
}

show_users() {
    print_header

    if [[ ! -f "$USERS_DB" ]]; then
        echo -e "${RED}║  No users database found at: $USERS_DB              ║${RESET}"
        print_footer
        return
    fi

    local count=0
    while IFS=' ' read -r username limit; do
        [[ -z "$username" || "$username" == "#"* ]] && continue
        local conns=$(count_connections "$username")
        local status=$(is_active "$username")
        printf "${RED}║${WHITE} %-18s${RED} ${status}  ${CYAN}%-10s${RED}║${RESET}\n" "$username" "$conns"
        ((count++))
    done < "$USERS_DB"

    if ((count == 0)); then
        echo -e "${RED}║${YELLOW}  No users found in database                    ${RED}║${RESET}"
    fi

    print_footer
}

while true; do
    show_users

    read -t 5 -n 1 -r _ 2>/dev/null
    if [[ $? -eq 0 ]]; then
        read -r -t 1 _ 2>/dev/null
        break
    fi
done

exit 0
