#!/bin/bash
clear
echo -e "\033[1;31mв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\033[0m"
echo -e "\033[1;37m  BACKUP AUTOMATICO - @Netxxus\033[0m"
echo -e "\033[1;31mв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\033[0m"
echo ""
echo -e "\033[1;37m  1)\033[1;33m Hacer Backup ahora\033[0m"
echo -e "\033[1;37m  2)\033[1;33m Activar Backup diario (cron)\033[0m"
echo -e "\033[1;37m  3)\033[1;33m Desactivar Backup diario\033[0m"
echo -e "\033[1;37m  4)\033[1;33m Ver Backups\033[0m"
echo -e "\033[1;37m  5)\033[1;33m Restaurar Backup\033[0m"
echo -e "\033[1;37m  0)\033[1;31m Volver\033[0m"
echo ""
echo -ne "\033[1;32m  Opcion:\033[1;37m "; read opc
case $opc in
    1)
        mkdir -p /root/backups
        fecha=$(date +%Y%m%d_%H%M%S)
        tar czf "/root/backups/backup_${fecha}.tar.gz" /root/usuarios.db /etc/SSHPlus/ /etc/openvpn/ 2>/dev/null
        tamano=$(du -h "/root/backup_${fecha}.tar.gz" 2>/dev/null | awk '{print $1}')
        echo -e "\033[1;32m  Backup creado: backup_${fecha}.tar.gz ($tamano)\033[0m"
        ;;
    2)
        (crontab -l 2>/dev/null | grep -v "backup_sshplus"; echo "0 3 * * * tar czf /root/backups/backup_\$(date +\%Y\%m\%d).tar.gz /root/usuarios.db /etc/SSHPlus/ /etc/openvpn/ 2>/dev/null") | crontab -
        echo -e "\033[1;32m  Backup diario activado a las 3:00 AM\033[0m"
        ;;
    3)
        crontab -l 2>/dev/null | grep -v "backup_sshplus" | crontab -
        echo -e "\033[1;33m  Backup diario desactivado\033[0m"
        ;;
    4)
        echo -e "\033[1;37m  Backups disponibles:\033[0m"
        ls -lh /root/backups/*.tar.gz 2>/dev/null || echo -e "\033[1;31m  No hay backups\033[0m"
        ;;
    5)
        echo -e "\033[1;37m  Backups disponibles:\033[0m"
        ls -lh /root/backups/*.tar.gz 2>/dev/null || { echo -e "\033[1;31m  No hay backups\033[0m"; exit 1; }
        echo ""
        echo -ne "\033[1;32m  Nombre del archivo:\033[1;37m "; read archivo
        tar xzf "/root/backups/$archivo" -C / 2>/dev/null
        [[ $? -eq 0 ]] && echo -e "\033[1;32m  Backup restaurado!\033[0m" || echo -e "\033[1;31m  Error al restaurar\033[0m"
        ;;
    0) exit 0 ;;
esac
echo ""
echo -ne "\033[1;37m  [ENTER] Volver"; read
