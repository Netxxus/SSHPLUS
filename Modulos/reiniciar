#!/bin/bash
clear
echo -e "\033[1;31mв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\033[0m"
echo -e "\033[1;37m  REINICIAR SERVICIOS - @Netxxus\033[0m"
echo -e "\033[1;31mв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\033[0m"
echo ""
echo -e "\033[1;37m  1)\033[1;33m Reiniciar SSH\033[0m"
echo -e "\033[1;37m  2)\033[1;33m Reiniciar OpenVPN\033[0m"
echo -e "\033[1;37m  3)\033[1;33m Reiniciar Dropbear\033[0m"
echo -e "\033[1;37m  4)\033[1;33m Reiniciar Apache\033[0m"
echo -e "\033[1;37m  5)\033[1;33m Reiniciar Squid\033[0m"
echo -e "\033[1;37m  6)\033[1;33m Reiniciar TODOS\033[0m"
echo -e "\033[1;37m  0)\033[1;31m Volver\033[0m"
echo ""
echo -ne "\033[1;32m  Opcion:\033[1;37m "; read opc
reiniciar() {
    svc=$1
    service "$svc" restart >/dev/null 2>&1 && echo -e "\033[1;32m  $svc reiniciado\033[0m" || echo -e "\033[1;31m  Error al reiniciar $svc\033[0m"
}
case $opc in
    1) reiniciar ssh ;;
    2) reiniciar openvpn ;;
    3) reiniciar dropbear ;;
    4) reiniciar apache2 ;;
    5) reiniciar squid ;;
    6) reiniciar ssh; reiniciar openvpn; reiniciar dropbear; reiniciar apache2; reiniciar squid ;;
    0) exit 0 ;;
esac
echo ""
echo -ne "\033[1;37m  [ENTER] Volver"; read
