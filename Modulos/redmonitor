#!/bin/bash
clear
print_header() {
    echo -e "\033[1;31mв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\033[0m"
    echo -e "\033[1;37m  MONITOR DE RED - @Netxxus\033[0m"
    echo -e "\033[1;31mв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\033[0m"
    echo ""
}
get_traffic() {
    awk 'NR>2 {
        split($0, a, ":");
        iface = a[1];
        gsub(/^[ \t]+/, "", iface);
        split(a[2], b);
        rx = b[1];
        tx = b[9];
        printf "%s %s %s\n", iface, rx, tx;
    }' /proc/net/dev
}
prev=()
while true; do
    clear
    print_header
    echo -e "\033[1;37m  INTERFAZ       RECIBIDO        ENVIADO       RECIBIDO/s   ENVIADO/s\033[0m"
    echo -e "\033[1;31mв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\033[0m"
    i=0
    while read -r iface rx tx; do
        [[ "$iface" == "lo" ]] && continue
        if [[ -n "${prev[$i]}" ]]; then
            old_rx=$(echo "${prev[$i]}" | awk '{print $2}')
            old_tx=$(echo "${prev[$i]}" | awk '{print $3}')
            drx=$(( (rx - old_rx) / 2 ))
            dtx=$(( (tx - old_tx) / 2 ))
            if [[ $drx -ge 1073741824 ]]; then
                rx_s="$(echo "scale=1; $drx/1073741824" | bc)GB/s"
            elif [[ $drx -ge 1048576 ]]; then
                rx_s="$(echo "scale=1; $drx/1048576" | bc)MB/s"
            elif [[ $drx -ge 1024 ]]; then
                rx_s="$(echo "scale=1; $drx/1024" | bc)KB/s"
            else
                rx_s="${drx}B/s"
            fi
            if [[ $dtx -ge 1073741824 ]]; then
                tx_s="$(echo "scale=1; $dtx/1073741824" | bc)GB/s"
            elif [[ $dtx -ge 1048576 ]]; then
                tx_s="$(echo "scale=1; $dtx/1048576" | bc)MB/s"
            elif [[ $dtx -ge 1024 ]]; then
                tx_s="$(echo "scale=1; $dtx/1024" | bc)KB/s"
            else
                tx_s="${dtx}B/s"
            fi
        else
            rx_s="---"
            tx_s="---"
        fi
        if [[ $rx -ge 1073741824 ]]; then
            rx_t="$(echo "scale=1; $rx/1073741824" | bc)GB"
        elif [[ $rx -ge 1048576 ]]; then
            rx_t="$(echo "scale=1; $rx/1048576" | bc)MB"
        else
            rx_t="$(echo "scale=1; $rx/1024" | bc)KB"
        fi
        if [[ $tx -ge 1073741824 ]]; then
            tx_t="$(echo "scale=1; $tx/1073741824" | bc)GB"
        elif [[ $tx -ge 1048576 ]]; then
            tx_t="$(echo "scale=1; $tx/1048576" | bc)MB"
        else
            tx_t="$(echo "scale=1; $tx/1024" | bc)KB"
        fi
        printf "\033[1;33m  %-12s \033[1;37m%-14s %-14s \033[1;32m%-12s %-12s\033[0m\n" "$iface" "$rx_t" "$tx_t" "$rx_s" "$tx_s"
        prev[$i]="$iface $rx $tx"
        ((i++))
    done < <(get_traffic)
    echo -e "\033[1;31mв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\033[0m"
    echo -e "\033[1;37m  [ENTER] Volver al menu\033[0m"
    echo ""
    read -t 2 -n 1 key 2>/dev/null || key=""
    [[ -z "$key" ]] && continue
    break
done
