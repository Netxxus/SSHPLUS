#!/bin/bash
clear
echo -e "\033[1;31m═══════════════════════════════════════\033[0m"
echo -e "\033[1;37m  VELOCIDAD POR USUARIO - @Netxxus\033[0m"
echo -e "\033[1;31m═══════════════════════════════════════\033[0m"
echo ""
echo -e "\033[1;37m  1)\033[1;33m Ver limites actuales\033[0m"
echo -e "\033[1;37m  2)\033[1;33m Establecer limite a usuario\033[0m"
echo -e "\033[1;37m  3)\033[1;33m Quitar limite a usuario\033[0m"
echo -e "\033[1;37m  0)\033[1;31m Volver\033[0m"
echo ""
echo -ne "\033[1;32m  Opcion:\033[1;37m "; read opc
case $opc in
    1)
        echo ""
        echo -e "\033[1;33m  Limites de ancho de banda:\033[0m"
        echo -e "\033[1;31m─────────────────────────────────────────\033[0m"
        echo -e "\033[1;37m  USUARIO       BAJADA        SUBIDA\033[0m"
        echo -e "\033[1;31m─────────────────────────────────────────\033[0m"
        tc class show dev eth0 2>/dev/null | grep "class htb" | while read line; do
            user=$(echo "$line" | grep -oP '1:\K[0-9]+' | head -1)
            rate=$(echo "$line" | grep -oP 'rate \K[0-9]+[a-zA-Z]+' | head -1)
            [[ -n "$user" ]] && echo -e "  \033[1;33mUsuario $user \033[1;37m$rate\033[0m"
        done
        echo -e "\033[1;31m─────────────────────────────────────────\033[0m"
        ;;
    2)
        echo ""
        echo -ne "\033[1;32m  Usuario:\033[1;37m "; read usuario
        [[ -z "$usuario" ]] && { echo -e "\033[1;31m  Usuario vacio!\033[0m"; sleep 2; exit 1; }
        echo -ne "\033[1;32m  Limite BAJADA (ej: 500kbit, 1mbit):\033[1;37m "; read bajada
        echo -ne "\033[1;32m  Limite SUBIDA (ej: 500kbit, 1mbit):\033[1;37m "; read subida
        [[ -z "$bajada" || -z "$subida" ]] && { echo -e "\033[1;31m  Datos vacios!\033[0m"; sleep 2; exit 1; }
        uid=$(id -u "$usuario" 2>/dev/null)
        [[ -z "$uid" ]] && { echo -e "\033[1;31m  Usuario no existe!\033[0m"; sleep 2; exit 1; }
        tc qdisc add dev eth0 root handle 1: htb default 100 2>/dev/null
        tc class add dev eth0 parent 1: classid 1:${uid} htb rate "$bajada" ceil "$bajada" 2>/dev/null
        tc filter add dev eth0 protocol ip parent 1:0 prio 1 u32 match ip dst 0.0.0.0/0 flowid 1:${uid} 2>/dev/null
        echo -e "\033[1;32m  Limite aplicado a $usuario: BAJADA=$bajada SUBIDA=$subida\033[0m"
        ;;
    3)
        echo ""
        echo -ne "\033[1;32m  Usuario:\033[1;37m "; read usuario
        uid=$(id -u "$usuario" 2>/dev/null)
        [[ -z "$uid" ]] && { echo -e "\033[1;31m  Usuario no existe!\033[0m"; sleep 2; exit 1; }
        tc class del dev eth0 parent 1: classid 1:${uid} 2>/dev/null
        echo -e "\033[1;32m  Limite eliminado de $usuario\033[0m"
        ;;
    0) exit 0 ;;
esac
echo ""
echo -ne "\033[1;37m  [ENTER] Volver"; read
