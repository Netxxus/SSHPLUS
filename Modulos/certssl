#!/bin/bash
clear
echo -e "\033[1;31mв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\033[0m"
echo -e "\033[1;37m  CERTIFICADO SSL - @Netxxus\033[0m"
echo -e "\033[1;31mв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\033[0m"
echo ""
echo -e "\033[1;37m  1)\033[1;33m Generar certificado auto-firmado\033[0m"
echo -e "\033[1;37m  2)\033[1;33m Ver certificado actual\033[0m"
echo -e "\033[1;37m  3)\033[1;33m Eliminar certificado\033[0m"
echo -e "\033[1;37m  0)\033[1;31m Volver\033[0m"
echo ""
echo -ne "\033[1;32m  Opcion:\033[1;37m "; read opc
case $opc in
    1)
        echo ""
        echo -ne "\033[1;32m  Dominio (ej: mitortuga.com):\033[1;37m "; read dominio
        [[ -z "$dominio" ]] && { echo -e "\033[1;31m  Dominio vacio!\033[0m"; sleep 2; exit 1; }
        mkdir -p /etc/ssl/custom
        openssl req -x509 -nodes -newkey rsa:2048 \
            -keyout /etc/ssl/custom/${dominio}.key \
            -out /etc/ssl/custom/${dominio}.crt \
            -days 3650 \
            -subj "/C=BR/ST=Local/L=Local/O=SSHPlus/CN=${dominio}" 2>/dev/null
        if [[ -f "/etc/ssl/custom/${dominio}.crt" ]]; then
            echo -e "\033[1;32m  Certificado generado!\033[0m"
            echo -e "\033[1;37m  Cert: /etc/ssl/custom/${dominio}.crt\033[0m"
            echo -e "\033[1;37m  Key:  /etc/ssl/custom/${dominio}.key\033[0m"
            openssl x509 -in "/etc/ssl/custom/${dominio}.crt" -noout -dates 2>/dev/null
        else
            echo -e "\033[1;31m  Error al generar certificado!\033[0m"
        fi
        ;;
    2)
        echo ""
        echo -e "\033[1;33m  Certificados en /etc/ssl/custom/:\033[0m"
        echo -e "\033[1;31mв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\033[0m"
        if ls /etc/ssl/custom/*.crt >/dev/null 2>&1; then
            for crt in /etc/ssl/custom/*.crt; do
                echo -e "  \033[1;33m$(basename "$crt" .crt)\033[0m"
                openssl x509 -in "$crt" -noout -subject -dates 2>/dev/null | sed 's/^/    /'
                echo ""
            done
        else
            echo -e "\033[1;31m  No hay certificados\033[0m"
        fi
        ;;
    3)
        echo ""
        echo -ne "\033[1;32m  Nombre del dominio:\033[1;37m "; read dominio
        rm -f /etc/ssl/custom/${dominio}.crt /etc/ssl/custom/${dominio}.key
        echo -e "\033[1;32m  Certificado eliminado\033[0m"
        ;;
    0) exit 0 ;;
esac
echo ""
echo -ne "\033[1;37m  [ENTER] Volver"; read
